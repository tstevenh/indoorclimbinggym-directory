---
import { getRandomProducts, type Product } from '../data/affiliateProducts';

interface Props {
  title?: string;
  subtitle?: string;
  products?: Product[];
  variant?: 'horizontal' | 'vertical';
  count?: number;
  category?: string;
  ctaLabel?: string;
}

const {
  title = "Gear Up for Your Visit",
  subtitle = "Essential gear recommended for indoor climbing.",
  variant = "horizontal",
  count = 3,
  category,
  ctaLabel = 'Check price on Amazon',
  products = getRandomProducts(count, category)
} = Astro.props;

const sanitize = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '_')
    .replace(/^_+|_+$/g, '')
    .slice(0, 64);

const blockTitleSlug = sanitize(title);
const categorySlug = sanitize(category || 'general');
const variantSlug = sanitize(variant);

// Layout classes based on variant and count
let containerClasses = "grid grid-cols-1 md:grid-cols-3 gap-6";

if (variant === 'vertical') {
  containerClasses = "flex flex-col gap-4";
} else if (count >= 5) {
  // Adaptive grid for more products
  containerClasses = "grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6";
} else if (count === 4) {
  containerClasses = "grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6";
}

const cardClasses = variant === 'vertical'
  ? "flex flex-row md:flex-col h-24 md:h-auto" // Compact row on small, stack on vertical usage
  : "flex flex-col h-full";

const imageContainerClasses = variant === 'vertical'
  ? "w-24 md:w-full h-full md:h-48 flex-shrink-0"
  : "h-48 w-full";
---

{products && products.length > 0 && (
<section class={`bg-[#1f1f1f] rounded-2xl border border-white/10 p-6 my-8 ${variant === 'vertical' ? 'max-w-xs mx-auto' : ''}`} style={{ boxShadow: '0 8px 32px rgba(0,0,0,0.4)' }}>
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-2">
    <div>
      <div role="heading" aria-level="2" class={`${variant === 'vertical' ? 'text-xl' : 'text-2xl'} font-display font-bold text-white flex items-center gap-2`}>
        <svg class="w-6 h-6 text-[#00e676]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        {title}
      </div>
      {subtitle && <p class="text-white/50 text-sm mt-1">{subtitle}</p>}
      <p class="text-[11px] text-white/30 mt-2">Disclosure: We may earn a commission from qualifying purchases at no extra cost to you.</p>
    </div>
    <span class="text-[10px] text-white/40 uppercase tracking-wider self-start md:self-center font-mono">
      Common picks
    </span>
  </div>

  <div class={containerClasses}>
    {products.map((product) => (
      <a 
        href={product.link} 
        target="_blank" 
        rel="noopener noreferrer sponsored"
        data-affiliate-link="true"
        data-affiliate-program="amazon"
        data-affiliate-source="affiliate_block"
        data-affiliate-intent={categorySlug}
        data-affiliate-position={`${variantSlug}_card`}
        data-affiliate-variant={variantSlug}
        data-affiliate-destination="amazon"
        data-affiliate-product={product.id}
        data-affiliate-product-name={product.name}
        data-affiliate-link-text={product.name}
        data-affiliate-title={title}
        data-affiliate-block-id={blockTitleSlug}
        data-affiliate-category={categorySlug}
        data-affiliate-outbound-url={product.link}
        class={`group ${cardClasses} bg-[#2d2d2d] border border-white/5 rounded-xl overflow-hidden hover:border-[#00e676]/30 transition-all duration-300 no-underline !no-underline`}
      >
        <div class={`relative bg-[#1f1f1f] p-4 flex items-center justify-center overflow-hidden ${imageContainerClasses}`}>
          <img 
            src={product.imageUrl} 
            alt={product.name} 
            class="object-contain h-full w-full group-hover:scale-105 transition-transform duration-300"
            loading="lazy"
          />
          {product.badge && (
            <span class="absolute top-2 right-2 bg-[#00e676] text-black text-[10px] font-bold px-2 py-1 rounded font-mono">
              {product.badge}
            </span>
          )}
        </div>
        
        <div class="p-4 flex flex-col flex-grow bg-[#2d2d2d] justify-between">
          <div>
            <div role="heading" aria-level="3" class={`font-display font-bold text-white group-hover:text-[#00e676] transition-colors mb-1 line-clamp-1 ${variant === 'vertical' ? 'text-sm' : ''}`}>
              {product.name}
            </div>
            <p class="text-white/50 text-xs mb-2 line-clamp-2">
              {product.description}
            </p>
          </div>
          
          <div class="flex justify-between items-center pt-2 border-t border-white/10 mt-auto">
            <span class="font-bold text-white text-sm font-mono">{product.price}</span>
            <span class="text-xs text-[#00e676] font-medium flex items-center gap-1 group-hover:translate-x-1 transition-transform font-mono">
              {ctaLabel}
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </div>
      </a>
    ))}
  </div>

  <div class="mt-6 text-center border-t border-white/10 pt-4">
    <a href="/gear/" class="inline-flex items-center gap-2 text-sm text-[#00e676] font-medium hover:text-[#00c853] transition-colors group no-underline !no-underline font-mono">
      View All Recommended Gear
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</section>
)}

<script>
  if (typeof window !== 'undefined') {
    const trackingWindow = window as Window & {
      __genericAffiliateTrackingInitialized?: boolean;
      posthog?: {
        capture?: (eventName: string, properties?: Record<string, unknown>) => void;
      };
    };

    if (!trackingWindow.__genericAffiliateTrackingInitialized) {
      trackingWindow.__genericAffiliateTrackingInitialized = true;

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const link = target.closest('[data-affiliate-link="true"]');
        if (!(link instanceof HTMLAnchorElement)) return;

        const posthogClient = trackingWindow.posthog;
        if (!posthogClient || typeof posthogClient.capture !== 'function') return;

        posthogClient.capture('affiliate_click', {
          affiliate_program: link.getAttribute('data-affiliate-program') || 'amazon',
          affiliate_source: link.getAttribute('data-affiliate-source') || 'affiliate_block',
          affiliate_intent: link.getAttribute('data-affiliate-intent') || 'general',
          affiliate_position: link.getAttribute('data-affiliate-position') || 'unknown',
          affiliate_variant: link.getAttribute('data-affiliate-variant') || 'default',
          affiliate_destination: link.getAttribute('data-affiliate-destination') || 'amazon',
          affiliate_block_title: link.getAttribute('data-affiliate-title') || 'affiliate_block',
          affiliate_block_id: link.getAttribute('data-affiliate-block-id') || 'affiliate_block',
          affiliate_product_id: link.getAttribute('data-affiliate-product') || 'unknown',
          affiliate_product_name: link.getAttribute('data-affiliate-product-name') || 'unknown',
          affiliate_category: link.getAttribute('data-affiliate-category') || 'general',
          link_text:
            link.getAttribute('data-affiliate-link-text') ||
            link.getAttribute('data-affiliate-product-name') ||
            'unknown',
          page_path: window.location.pathname,
          outbound_url: link.getAttribute('data-affiliate-outbound-url') || link.href,
        });
      });
    }
  }
</script>
