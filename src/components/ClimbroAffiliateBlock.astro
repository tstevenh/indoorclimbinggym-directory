---
import ClimbroTrackedLink from './ClimbroTrackedLink.astro';

interface Props {
  title?: string;
  subtitle?: string;
  source?: string;
  compact?: boolean;
}

const {
  title = 'Structured finger training, without guesswork',
  subtitle = 'Pick the path that fits your commitment level and training style.',
  source = 'climbro_block',
  compact = false,
} = Astro.props;
---

<section class={`my-8 rounded-2xl border border-white/10 bg-[#1f1f1f] overflow-hidden ${compact ? 'max-w-3xl' : ''}`}>
  <div class="grid md:grid-cols-12 gap-0">
    <div class="md:col-span-4 bg-[#171717]">
      <img
        src="/images/blog/climbro/Climbro_Pro/climbro-detail-3.jpg"
        alt="Climbro smart hangboard"
        class="w-full h-full object-cover min-h-[170px]"
        loading="lazy"
      />
    </div>
    <div class="md:col-span-8 p-5 md:p-6">
      <h3 class="text-lg md:text-xl font-display font-bold text-white mb-2">{title}</h3>
      <p class="text-sm md:text-base text-white/70 mb-4">{subtitle}</p>

      <div class="flex flex-wrap gap-2 mb-3">
        <ClimbroTrackedLink
          href="https://climbro.com/rent/"
          label="Start with Rental"
          intent="rent"
          source={source}
          position="mid_block"
          class="!no-underline rounded-lg border border-[#00e676]/40 !text-[#9cffc3] hover:bg-[#00e676]/20 px-3 py-2 text-sm font-semibold transition"
        />
        <ClimbroTrackedLink
          href="https://climbro.com/shop/"
          label="Buy from Shop"
          intent="shop"
          source={source}
          position="mid_block"
          class="!no-underline rounded-lg border border-[#00e676]/40 !text-[#9cffc3] hover:bg-[#00e676]/20 px-3 py-2 text-sm font-semibold transition"
        />
        <ClimbroTrackedLink
          href="https://climbro.com/30-day-trial/"
          label="See 30-Day Trial"
          intent="trial"
          source={source}
          position="mid_block"
          class="!no-underline rounded-lg border border-[#00e676]/40 !text-[#9cffc3] hover:bg-[#00e676]/20 px-3 py-2 text-sm font-semibold transition"
        />
      </div>

      <p class="text-xs text-white/45">Disclosure: affiliate links may earn us a commission at no extra cost to you.</p>
    </div>
  </div>
</section>
