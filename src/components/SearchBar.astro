---
/**
 * SearchBar Component - Dark Theme Style
 * Replicated from app 2/ design
 */

interface Props {
  placeholder?: string;
  initialValue?: string;
  large?: boolean;
}

const {
  placeholder = 'Search by city, zip, or gym name...',
  initialValue = '',
  large = false,
} = Astro.props;

const inputClasses = large
  ? 'flex-1 px-6 py-5 bg-transparent text-white placeholder:text-white/40 outline-none text-lg'
  : 'flex-1 px-4 py-3 bg-transparent text-white placeholder:text-white/40 outline-none';
---

<form action="/search" method="get" class="w-full" role="search">
  <div 
    class="relative flex items-center max-w-2xl bg-gradient-to-br from-[#2d2d2d] to-[#1f1f1f] rounded-[30px_70px_70px_30px/30px_30px_70px_70px] border-2 border-white/10 shadow-[0_8px_32px_rgba(0,0,0,0.5)] focus-within:border-[#00e676] focus-within:shadow-[0_0_30px_rgba(0,230,118,0.3)] transition-all duration-300 overflow-visible"
  >
    <div class="pl-6">
      <svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
    </div>
    <input
      type="search"
      name="q"
      value={initialValue}
      placeholder={placeholder}
      class={inputClasses}
      autocomplete="off"
      aria-label="Search climbing gyms"
    />
    <button 
      type="submit" 
      class="btn-jug flex items-center gap-1 sm:gap-2 m-1 sm:m-2"
      aria-label="Submit search"
    >
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <span class="hidden sm:inline">SEND IT</span>
      <span class="sm:hidden">GO</span>
    </button>
  </div>
</form>
