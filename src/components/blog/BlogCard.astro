---
/**
 * BlogCard Component
 * Displays a preview card for a blog post
 */

interface Props {
  slug: string;
  title: string;
  description: string;
  publishedDate: Date;
  author: string;
  category: string;
  heroImage: string;
  heroImageAlt: string;
  readingTime?: number;
}

const {
  slug,
  title,
  description,
  publishedDate,
  author,
  category,
  heroImage,
  heroImageAlt,
  readingTime,
} = Astro.props;

// Format date
const formattedDate = publishedDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Category colors - dark theme
const categoryColors: { [key: string]: string } = {
  guides: 'bg-[#2979ff]/20 text-[#2979ff] border-[#2979ff]/30',
  tips: 'bg-[#00e676]/20 text-[#00e676] border-[#00e676]/30',
  reviews: 'bg-[#ff2d7a]/20 text-[#ff2d7a] border-[#ff2d7a]/30',
  industry: 'bg-[#ff9100]/20 text-[#ff9100] border-[#ff9100]/30',
  gear: 'bg-[#ffea00]/20 text-[#ffea00] border-[#ffea00]/30',
};

const categoryColor = categoryColors[category] || 'bg-white/10 text-white/80 border-white/10';
---

<article class="bg-[#1f1f1f] rounded-xl border border-white/10 overflow-hidden hover:border-[#2979ff]/50 transition-all duration-300 group" style="box-shadow: 0 8px 32px rgba(0,0,0,0.4);">
  <a href={`/blog/${slug}/`} class="block">
    <div class="aspect-video w-full overflow-hidden bg-[#2d2d2d]">
      <img
        src={heroImage}
        alt={heroImageAlt}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
  </a>

  <div class="p-6">
    <div class="flex items-center gap-2 mb-3">
      <span class={`text-xs font-semibold px-3 py-1 rounded-full border ${categoryColor}`}>
        {category.charAt(0).toUpperCase() + category.slice(1)}
      </span>
      {readingTime && (
        <span class="text-xs text-white/50">
          {readingTime} min read
        </span>
      )}
    </div>

    <a href={`/blog/${slug}/`} class="block group/title">
      <h3 class="text-xl font-bold text-white mb-2 group-hover/title:text-[#2979ff] transition-colors line-clamp-2 font-display">
        {title}
      </h3>
    </a>

    <p class="text-white/60 mb-4 line-clamp-3">
      {description}
    </p>

    <div class="flex items-center justify-between text-sm text-white/50">
      <span class="font-medium text-white/70">{author}</span>
      <time datetime={publishedDate.toISOString()}>{formattedDate}</time>
    </div>
  </div>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
