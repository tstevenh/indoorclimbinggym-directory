---
interface Props {
  href: string;
  label: string;
  intent: string;
  source: string;
  position: string;
  pageType?: string;
  variant?: string;
  class?: string;
}

const {
  href,
  label,
  intent,
  source,
  position,
  pageType = 'article',
  variant = 'default',
  class: className = '',
} = Astro.props;
const hasDefaultSlot = Astro.slots.has('default');

const sanitize = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '_')
    .replace(/^_+|_+$/g, '')
    .slice(0, 64);

const sourceSlug = sanitize(source);
const positionSlug = sanitize(position);
const intentSlug = sanitize(intent);
const variantSlug = sanitize(variant);

const url = new URL(href);
url.searchParams.set('wpam_id', '23');
url.searchParams.set('subid', `${sourceSlug}_${positionSlug}_${intentSlug}`);
url.searchParams.set('utm_source', 'indoorclimbinggym');
url.searchParams.set('utm_medium', 'affiliate');
url.searchParams.set('utm_campaign', `climbro_${sourceSlug}_${positionSlug}_${intentSlug}_${variantSlug}`);

const destination = sanitize(url.pathname.replace(/^\/|\/$/g, '') || 'home');
const articleSlugMatch = Astro.url.pathname.match(/^\/blog\/([^/]+)\/?$/);
const articleSlug = articleSlugMatch ? articleSlugMatch[1] : '';

const inlineCodeClass =
  positionSlug === 'body_inline'
    ? 'inline-block rounded bg-white/10 px-1.5 py-0.5 font-mono text-[0.95em] text-[#e3d46f] no-underline !no-underline hover:bg-white/15 transition-colors'
    : '';

const finalClass = [inlineCodeClass, className].filter(Boolean).join(' ');
---

<a
  href={url.toString()}
  target="_blank"
  rel="noopener noreferrer sponsored"
  data-affiliate-link="climbro"
  data-affiliate-program="climbro"
  data-affiliate-source={sourceSlug}
  data-affiliate-intent={intentSlug}
  data-affiliate-position={positionSlug}
  data-affiliate-page-type={pageType}
  data-affiliate-variant={variantSlug}
  data-affiliate-subid={`${sourceSlug}_${positionSlug}_${intentSlug}`}
  data-affiliate-destination={destination}
  data-affiliate-outbound-url={url.toString()}
  data-affiliate-article-slug={articleSlug}
  class={finalClass}
>
  {hasDefaultSlot ? <slot /> : label}
</a>

<script>
  if (typeof window !== 'undefined') {
    const trackingWindow = window as Window & {
      __climbroAffiliateTrackingInitialized?: boolean;
      posthog?: {
        capture?: (eventName: string, properties?: Record<string, unknown>) => void;
      };
    };

    if (!trackingWindow.__climbroAffiliateTrackingInitialized) {
      trackingWindow.__climbroAffiliateTrackingInitialized = true;

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const link = target.closest('[data-affiliate-link="climbro"]');
        if (!(link instanceof HTMLAnchorElement)) return;

        const posthogClient = trackingWindow.posthog;
        if (!posthogClient || typeof posthogClient.capture !== 'function') return;

        const affiliateProgram = link.getAttribute('data-affiliate-program') || 'climbro';
        const affiliateSource = link.getAttribute('data-affiliate-source') || 'unknown';
        const affiliateIntent = link.getAttribute('data-affiliate-intent') || 'unknown';
        const affiliatePosition = link.getAttribute('data-affiliate-position') || 'unknown';
        const affiliatePageType = link.getAttribute('data-affiliate-page-type') || 'unknown';
        const affiliateVariant = link.getAttribute('data-affiliate-variant') || 'default';
        const affiliateSubid = link.getAttribute('data-affiliate-subid') || 'unknown';
        const affiliateDestination = link.getAttribute('data-affiliate-destination') || 'unknown';
        const outboundUrl = link.getAttribute('data-affiliate-outbound-url') || link.href;
        const articleSlug = link.getAttribute('data-affiliate-article-slug') || null;

        posthogClient.capture('affiliate_click', {
          affiliate_program: affiliateProgram,
          affiliate_source: affiliateSource,
          affiliate_intent: affiliateIntent,
          affiliate_position: affiliatePosition,
          affiliate_page_type: affiliatePageType,
          affiliate_variant: affiliateVariant,
          affiliate_subid: affiliateSubid,
          affiliate_destination: affiliateDestination,
          link_text: (link.textContent || '').trim().slice(0, 100),
          page_path: window.location.pathname,
          outbound_url: outboundUrl,
          article_slug: articleSlug,
        });
      });
    }
  }
</script>
