---
/**
 * HelpfulGuides Component - Dark Theme
 * Links to relevant blog posts based on context
 */

interface Props {
  beginner_friendly?: boolean;
  includeAll?: boolean;
}

const { beginner_friendly = false, includeAll = false } = Astro.props;

// Define helpful guide links
const guides = [
  {
    title: "Beginner's Guide to Climbing Gyms",
    url: '/blog/beginners-guide-to-climbing-gyms/',
    showIf: beginner_friendly || includeAll,
  },
  {
    title: 'What to Wear Indoor Rock Climbing',
    url: '/blog/what-to-wear-indoor-rock-climbing/',
    showIf: true,
  },
  {
    title: 'Is Climbing Gym Membership Worth It?',
    url: '/blog/is-climbing-gym-membership-worth-it/',
    showIf: true,
  },
  {
    title: 'Bouldering vs Rope Climbing',
    url: '/blog/bouldering-vs-rope-climbing/',
    showIf: includeAll,
  },
];

const visibleGuides = guides.filter(g => g.showIf).slice(0, 3);
---

{visibleGuides.length > 0 && (
  <div class="bg-[#1f1f1f] rounded-2xl border border-white/10 p-6" style={{ boxShadow: '0 8px 32px rgba(0,0,0,0.4)' }}>
    <h3 class="font-display font-bold text-white mb-4">Helpful Guides</h3>
    <div class="space-y-3">
      {visibleGuides.map((guide) => (
        <a
          href={guide.url}
          class="block p-3 bg-[#2d2d2d] rounded-xl border border-white/5 hover:border-[#00e676]/30 transition-all group"
        >
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-white group-hover:text-[#00e676] transition-colors">
              {guide.title}
            </span>
            <svg
              class="w-4 h-4 text-white/20 group-hover:text-[#00e676] transition-colors"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              />
            </svg>
          </div>
        </a>
      ))}
    </div>
    <a
      href="/blog/"
      class="block mt-4 text-[#00e676] text-sm font-medium hover:text-[#00c853] transition-colors font-mono"
    >
      View all guides →
    </a>
  </div>
)}
