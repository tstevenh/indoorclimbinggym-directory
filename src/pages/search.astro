---
/**
 * Search Page - Dark Theme
 * Comprehensive search and filtering page for climbing gyms
 * Supports URL parameter-based filtering for shareable links
 */

// Enable SSR for pagination (required for URL param-based page navigation)
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import GymCard from '../components/GymCard.astro';
import FilterSidebar from '../components/FilterSidebar.astro';
import Pagination from '../components/Pagination.astro';
import SearchBar from '../components/SearchBar.astro';
import { fetchGyms } from '../config/api';
import { getStateName } from '../utils/states';

// Fetch gyms from API
let gyms: any[] = [];
let apiError = false;

try {
  gyms = await fetchGyms();
} catch (error) {
  console.error('Failed to fetch gyms:', error);
  apiError = true;
}

// Get URL search parameters
const searchParams = Astro.url.searchParams;

// Start with all gyms
let filteredGyms = [...gyms];

// Track active filters for display
const activeFilters: Array<{ label: string; param: string; value: string }> = [];

// Text search filter
const query = searchParams.get('q');
if (query && query.trim()) {
  const searchTerm = query.toLowerCase().trim();
  filteredGyms = filteredGyms.filter(
    (g) =>
      g.name?.toLowerCase().includes(searchTerm) ||
      g.city?.toLowerCase().includes(searchTerm) ||
      g.address?.toLowerCase().includes(searchTerm) ||
      g.postal_code?.toLowerCase().includes(searchTerm) ||
      g.amenities?.toLowerCase().includes(searchTerm) ||
      g.description_short?.toLowerCase().includes(searchTerm)
  );
  activeFilters.push({ label: `Search: "${query}"`, param: 'q', value: query });
}

// State filter
const stateParam = searchParams.get('state');
if (stateParam) {
  const stateFullName = getStateName(stateParam);
  filteredGyms = filteredGyms.filter((g) => g.region === stateFullName);
  activeFilters.push({ label: `State: ${stateFullName}`, param: 'state', value: stateParam });
}

// City filter
let cityDisplay: string | null = null;
const cityParam = searchParams.get('city');
if (cityParam) {
  filteredGyms = filteredGyms.filter(
    (g) => g.city.toLowerCase() === cityParam.toLowerCase()
  );
  // Capitalize city name for display
  cityDisplay = cityParam.charAt(0).toUpperCase() + cityParam.slice(1).toLowerCase();
  activeFilters.push({ label: `City: ${cityDisplay}`, param: 'city', value: cityParam });
}

// Climbing types filter (comma-separated)
const climbingTypesParam = searchParams.get('climbing_types');
if (climbingTypesParam) {
  const types = climbingTypesParam.split(',').map((t) => t.trim());
  filteredGyms = filteredGyms.filter((g) =>
    types.some((type) => g.climbing_types?.includes(type))
  );
  const typesDisplay = types.map((t) => t.replace(/_/g, ' ')).join(', ');
  activeFilters.push({ label: `Type: ${typesDisplay}`, param: 'climbing_types', value: climbingTypesParam });
}

// Amenities filter (comma-separated, must have ALL)
const amenitiesParam = searchParams.get('amenities');
if (amenitiesParam) {
  const amenityList = amenitiesParam.split(',').map((a) => a.trim());
  filteredGyms = filteredGyms.filter((g) =>
    amenityList.every((amenity) => g.amenities?.includes(amenity))
  );
  const amenitiesDisplay = amenityList.map((a) => a.replace(/_/g, ' ')).join(', ');
  activeFilters.push({ label: `Amenities: ${amenitiesDisplay}`, param: 'amenities', value: amenitiesParam });
}

// Price range filters
const minPriceParam = searchParams.get('min_price');
const maxPriceParam = searchParams.get('max_price');

if (minPriceParam) {
  const minPrice = parseInt(minPriceParam);
  filteredGyms = filteredGyms.filter((g) => g.day_pass_price_local >= minPrice);
  activeFilters.push({ label: `Min Price: $${minPrice}`, param: 'min_price', value: minPriceParam });
}

if (maxPriceParam) {
  const maxPrice = parseInt(maxPriceParam);
  filteredGyms = filteredGyms.filter((g) => g.day_pass_price_local <= maxPrice);
  activeFilters.push({ label: `Max Price: $${maxPrice}`, param: 'max_price', value: maxPriceParam });
}

// Min rating filter
const minRatingParam = searchParams.get('min_rating');
if (minRatingParam) {
  const minRating = parseFloat(minRatingParam);
  filteredGyms = filteredGyms.filter((g) => g.rating >= minRating);
  activeFilters.push({ label: `Rating: ${minRating}+ stars`, param: 'min_rating', value: minRatingParam });
}

// Boolean filters
const beginnerFriendlyParam = searchParams.get('beginner_friendly');
if (beginnerFriendlyParam === 'true') {
  filteredGyms = filteredGyms.filter((g) => g.beginner_friendly);
  activeFilters.push({ label: 'Beginner Friendly', param: 'beginner_friendly', value: 'true' });
}

const studentDiscountParam = searchParams.get('student_discount');
if (studentDiscountParam === 'true') {
  filteredGyms = filteredGyms.filter((g) => g.student_discount);
  activeFilters.push({ label: 'Student Discount', param: 'student_discount', value: 'true' });
}

// Pagination logic
const GYMS_PER_PAGE = 12;
const currentPage = parseInt(searchParams.get('page') || '1');
const totalPages = Math.ceil(filteredGyms.length / GYMS_PER_PAGE);
const startIndex = (currentPage - 1) * GYMS_PER_PAGE;
const endIndex = startIndex + GYMS_PER_PAGE;
const paginatedGyms = filteredGyms.slice(startIndex, endIndex);

// Build baseUrl preserving all search params except page
const paginationParams = new URLSearchParams(Astro.url.search);
paginationParams.delete('page'); // Remove page param to build clean baseUrl
const baseUrl = paginationParams.toString()
  ? `/search?${paginationParams.toString()}&`
  : '/search?';

// SEO setup
const hasFilters = activeFilters.length > 0;
const resultsCount = filteredGyms.length;
const totalCount = gyms.length;

const totalGyms = gyms.length;
const title = hasFilters
  ? `${resultsCount} Climbing Gyms Found | Indoor Climbing Gym`
  : 'Search Climbing Gyms | Filter by Location & Amenities';

const description = hasFilters
  ? `Browse ${resultsCount} indoor climbing gyms matching your criteria. Find the perfect climbing gym with our advanced search and filtering tools.`
  : `Search ${totalGyms}+ climbing gyms. Filter by state, city, climbing type, amenities & price. Compare ratings & find your perfect gym.`;

// Only index the base search page (no parameters)
const noindex = hasFilters;

// Canonical URL: always point to clean /search/ URL (no query params)
const canonical = 'https://www.indoorclimbinggym.com/search/';

const breadcrumbs = [
  { label: 'Home', url: 'https://www.indoorclimbinggym.com/' },
  { label: 'Search', url: 'https://www.indoorclimbinggym.com/search/' },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  noindex={noindex}
  breadcrumbs={breadcrumbs}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb Navigation -->
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center space-x-2 text-sm text-white/40">
        <li>
          <a href="/" class="hover:text-[#00e676] transition-colors">Home</a>
        </li>
        <li>
          <svg class="w-4 h-4 text-white/20" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
              clip-rule="evenodd"></path>
          </svg>
        </li>
        <li>
          <span class="text-white/60 font-medium">Search</span>
        </li>
      </ol>
    </nav>

    <!-- Page Header -->
    <header class="mb-8">
      <div class="mb-2">
        <span class="text-[#2979ff] text-sm font-mono tracking-widest">THE DIRECTORY</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-3">
        {hasFilters ? 'Search Results' : 'Search Climbing Gyms'}
      </h1>
      <p class="text-lg text-white/50 mb-6 max-w-2xl">
        {hasFilters
          ? `Found ${resultsCount} ${resultsCount === 1 ? 'gym' : 'gyms'} matching your criteria`
          : `Browse all ${totalCount} climbing gyms or use filters to refine your search`}
      </p>

      <!-- Search Bar -->
      <div class="max-w-2xl">
        <SearchBar placeholder="Search by city, gym name, or zip code..." initialValue={query || ''} />
      </div>
    </header>

    {cityParam && cityDisplay && (
      <div class="bg-gradient-to-r from-[#00e676]/10 to-[#2979ff]/10 border border-[#00e676]/20 rounded-2xl p-5 mb-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-4" style={{ boxShadow: '0 4px 16px rgba(0,0,0,0.3)' }}>
        <div>
          <div class="text-sm font-display font-semibold text-white mb-1">Climbers in {cityDisplay} are ranked here</div>
          <p class="text-sm text-white/50">See how your city stacks up this month on the leaderboard.</p>
        </div>
        <a
          href="/leaderboard/"
          class="btn-jug text-black text-sm inline-flex items-center gap-2"
        >
          View Leaderboard
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    )}

    <!-- API Error Alert -->
    {apiError && (
      <div class="bg-[#ff1744]/10 border border-[#ff1744]/30 rounded-xl p-4 mb-6">
        <div class="flex items-center">
          <svg class="w-5 h-5 text-[#ff1744] mr-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
          <div>
            <h3 class="font-semibold text-[#ff1744]">Unable to load gym data</h3>
            <p class="text-sm text-white/60">Please make sure the API server is running and try again.</p>
          </div>
        </div>
      </div>
    )}

    <!-- Active Filters Display -->
    {
      activeFilters.length > 0 && (
        <section class="mb-6 bg-[#1f1f1f] rounded-xl border border-white/10 p-4" style={{ boxShadow: '0 4px 16px rgba(0,0,0,0.3)' }}>
          <div class="flex items-center justify-between flex-wrap gap-3">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="text-sm font-display font-semibold text-white/70">Active Filters:</span>
              {activeFilters.map((filter) => (
                <button
                  data-param={filter.param}
                  data-value={filter.value}
                  class="filter-tag inline-flex items-center gap-2 bg-[#00e676] text-black px-3 py-1 rounded-full text-sm font-mono font-bold hover:bg-[#00c853] transition-colors"
                >
                  <span>{filter.label}</span>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M6 18L18 6M6 6l12 12"
                    />
                  </svg>
                </button>
              ))}
            </div>
            <a
              href="/search/"
              class="text-sm text-[#00e676] hover:text-[#00c853] font-medium transition-colors font-mono"
            >
              Clear All Filters
            </a>
          </div>
        </section>
      )
    }

    <!-- Main Content: Sidebar + Results Grid -->
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Left Sidebar: Filters -->
      <aside class="w-full lg:w-1/4 lg:sticky lg:top-24 lg:max-h-[calc(100vh-6rem)] lg:overflow-y-auto lg:scrollbar-thin">
        <FilterSidebar />
      </aside>

      <!-- Right: Results Grid -->
      <main class="w-full lg:w-3/4">
        {
          filteredGyms.length > 0 ? (
            <>
              <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                {paginatedGyms.map((gym, index) => (
                  <GymCard gym={gym} showCity={true} delay={index * 0.05} />
                ))}
              </div>

              <Pagination
                currentPage={currentPage}
                totalPages={totalPages}
                baseUrl={baseUrl}
              />
            </>
          ) : (
            <div class="bg-[#1f1f1f] rounded-2xl border border-white/10 p-12 text-center" style={{ boxShadow: '0 8px 32px rgba(0,0,0,0.4)' }}>
              <svg
                class="w-16 h-16 text-white/20 mx-auto mb-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
              <h2 class="text-2xl font-display font-bold text-white mb-2">No gyms found</h2>
              <p class="text-white/50 mb-6">
                We couldn't find any climbing gyms matching your criteria. Try adjusting your
                filters.
              </p>
              <a
                href="/search/"
                class="btn-jug text-black inline-flex items-center gap-2"
              >
                Clear All Filters
              </a>
            </div>
          )
        }
      </main>
    </div>
  </div>
</BaseLayout>

<script>
  // Handle filter tag removal (remove individual filter)
  document.addEventListener('DOMContentLoaded', () => {
    const filterTags = document.querySelectorAll('.filter-tag');

    filterTags.forEach((tag) => {
      tag.addEventListener('click', (e) => {
        const param = (e.currentTarget as HTMLElement).getAttribute('data-param');
        const value = (e.currentTarget as HTMLElement).getAttribute('data-value');

        if (param) {
          const url = new URL(window.location.href);
          url.searchParams.delete(param);
          window.location.href = url.toString();
        }
      });
    });
  });
</script>

<style>
  /* Ensure filter tags are interactive */
  .filter-tag {
    cursor: pointer;
  }

  .filter-tag:hover svg {
    transform: scale(1.1);
  }

  /* Custom scrollbar styling for filter sidebar */
  aside::-webkit-scrollbar {
    width: 6px;
  }

  aside::-webkit-scrollbar-track {
    background: transparent;
  }

  aside::-webkit-scrollbar-thumb {
    background: #3d3d3d;
    border-radius: 3px;
  }

  aside::-webkit-scrollbar-thumb:hover {
    background: #4d4d4d;
  }

  /* Firefox scrollbar styling */
  aside {
    scrollbar-width: thin;
    scrollbar-color: #3d3d3d transparent;
  }
</style>
