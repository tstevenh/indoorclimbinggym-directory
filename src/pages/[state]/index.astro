---
/**
 * State Landing Page - Dark Theme
 * SEO-optimized pages for "[state] climbing gyms" keywords
 * 2,000-2,500 words with city directory and state-level stats
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import GymCard from '../../components/GymCard.astro';
import { generateItemListSchema, generateFAQSchema } from '../../utils/schema';
import { generateStateTitle, generateStateDescription } from '../../utils/seo';
import { fetchGyms } from '../../config/api';
import { getStateSlug, getStateCode } from '../../utils/states';

export const prerender = true;

export async function getStaticPaths() {
  // Fetch gyms from API
  const gyms = await fetchGyms();

  // Get unique states
  const states = [...new Set(gyms.map(g => g.region))];

  return states.map(region => {
    const stateSlug = getStateSlug(region);
    const stateGyms = gyms.filter(g => g.region === region);

    return {
      params: { state: stateSlug },
      props: { region, stateGyms },
    };
  });
}

const { region, stateGyms } = Astro.props;
const { state: stateSlug } = Astro.params;
const stateCode = getStateCode(region); // Get 2-letter code (e.g., "TN", "NJ")

// Get unique cities
const cities = [...new Set(stateGyms.map(g => g.city))].sort();

// Calculate stats
const avgRating = (stateGyms.reduce((sum, g) => sum + g.rating, 0) / stateGyms.length).toFixed(1);
const minPrice = Math.min(...stateGyms.map(g => g.day_pass_price_local));
const maxPrice = Math.max(...stateGyms.map(g => g.day_pass_price_local));

// Get featured gyms only (sorted by rating, then alphabetically)
const featuredGyms = stateGyms
  .filter(g => g.featured === true)
  .sort((a, b) => {
    if (a.rating !== b.rating) return b.rating - a.rating;
    return a.name.localeCompare(b.name);
  });

// Find top-rated gym for SEO description
const topGym = [...stateGyms].sort((a, b) => (b.rating || 0) - (a.rating || 0))[0];

// Generate SEO data with CTR-optimized parameters
const title = generateStateTitle(region, stateGyms.length, cities.length);
const description = generateStateDescription(
  region,
  cities.length,
  stateGyms.length,
  topGym?.name,
  topGym?.rating
);
const pageUrl = `https://www.indoorclimbinggym.com/${stateSlug}`;

// Generate schemas
const itemListSchema = generateItemListSchema(
  stateGyms,
  `Climbing Gyms in ${region}`,
  pageUrl
);

// Generate FAQ
const faqs = [
  {
    question: `How many climbing gyms are in ${region}?`,
    answer: `There are ${stateGyms.length} indoor climbing gyms across ${cities.length} cities in ${region}. These facilities offer bouldering, top rope, lead climbing, and comprehensive training areas.`,
  },
  {
    question: `What cities in ${region} have climbing gyms?`,
    answer: `Climbing gyms in ${region} can be found in ${cities.join(', ')}. Each city offers unique facilities with different specialties and atmospheres.`,
  },
  {
    question: `What's the best climbing gym in ${region}?`,
    answer: `The highest-rated climbing gym in ${region} is ${[...stateGyms].sort((a, b) => b.rating - a.rating)[0]?.name} with a ${[...stateGyms].sort((a, b) => b.rating - a.rating)[0]?.rating}★ rating. However, the "best" gym depends on your location, climbing style preferences, and desired amenities.`,
  },
  {
    question: `How much does it cost to climb in ${region}?`,
    answer: `Day pass prices in ${region} range from $${minPrice} to $${maxPrice}. Most gyms also offer monthly memberships, punch cards, and student discounts that provide better value for regular climbers.`,
  },
  {
    question: `Are there bouldering gyms in ${region}?`,
    answer: `Yes! ${stateGyms.filter(g => g.climbing_types?.includes('bouldering')).length} of ${stateGyms.length} climbing facilities in ${region} offer bouldering. Some gyms are bouldering-only, while others combine bouldering with rope climbing.`,
  },
];

const faqSchema = generateFAQSchema(faqs);
const combinedSchema = [itemListSchema, faqSchema];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/' },
  { label: region, url: pageUrl },
];

// Helper function for singular/plural gym label
const gymLabel = (count: number) => count === 1 ? 'Gym' : 'Gyms';

// City colors for visual variety
const cityColors = ['#ff2d7a', '#00e676', '#2979ff', '#ffea00', '#ff9100', '#e040fb'];
---

<BaseLayout
  title={title}
  description={description}
  schema={combinedSchema}
  breadcrumbs={breadcrumbs}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-white/40 mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-[#00e676] transition-colors">Home</a></li>
        <li class="flex items-center gap-2">
          <span class="text-white/20">/</span>
          <span class="text-white/60 font-medium">{region}</span>
        </li>
      </ol>
    </nav>

    <!-- Header -->
    <header class="mb-12">
      <div class="mb-2">
        <span class="text-[#2979ff] text-sm font-mono tracking-widest">{stateCode} • {cities.length} CITIES</span>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-white mb-4">
        INDOOR CLIMBING
        <br />
        <span class="text-white/40">GYMS IN {region.toUpperCase()}</span>
      </h1>
      <p class="text-xl text-white/50 leading-relaxed mb-6 max-w-3xl">
        Discover {stateGyms.length} climbing gyms across {cities.length} cities in {region}.
        From bouldering-focused facilities to comprehensive climbing centers, find your perfect spot to climb.
      </p>

      <!-- Quick Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 bg-[#1f1f1f] rounded-2xl p-6 border border-white/10" style={{ boxShadow: '0 8px 32px rgba(0,0,0,0.4)' }}>
        <div class="text-center">
          <div class="font-mono font-bold text-4xl text-[#00e676]">{stateGyms.length}</div>
          <div class="text-sm text-white/40 font-mono tracking-wider mt-1">TOTAL GYMS</div>
        </div>
        <div class="text-center">
          <div class="font-mono font-bold text-4xl text-[#2979ff]">{cities.length}</div>
          <div class="text-sm text-white/40 font-mono tracking-wider mt-1">CITIES</div>
        </div>
        <div class="text-center">
          <div class="font-mono font-bold text-4xl text-[#ff2d7a]">{avgRating}★</div>
          <div class="text-sm text-white/40 font-mono tracking-wider mt-1">AVG RATING</div>
        </div>
        <div class="text-center">
          <div class="font-mono font-bold text-4xl text-[#ffea00]">${minPrice}-${maxPrice}</div>
          <div class="text-sm text-white/40 font-mono tracking-wider mt-1">DAY PASS</div>
        </div>
      </div>

      <div class="mt-6 bg-gradient-to-r from-[#00e676]/10 to-[#2979ff]/10 border border-[#00e676]/20 rounded-2xl p-5 flex flex-col md:flex-row items-start md:items-center justify-between gap-4" style={{ boxShadow: '0 4px 16px rgba(0,0,0,0.3)' }}>
        <div>
          <div class="text-sm font-display font-semibold text-white mb-1">{region} climbers are competing this month</div>
          <p class="text-sm text-white/50">See your city's rank and help push {region} higher.</p>
        </div>
        <a
          href="/leaderboard/"
          class="btn-jug text-black text-sm inline-flex items-center gap-2"
        >
          View Leaderboard
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </header>

    <!-- City Directory -->
    <section class="mb-12">
      <h2 class="text-3xl font-display font-bold text-white mb-2">
        BROWSE BY CITY
      </h2>
      <p class="text-white/50 mb-6">
        Select a city below to view all climbing gyms in that area, compare prices, and find the perfect facility for your needs.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {cities.map((city, index) => {
          const cityGyms = stateGyms.filter(g => g.city === city);
          const citySlug = city.toLowerCase().replace(/\s+/g, '-');
          const cityAvgRating = (cityGyms.reduce((sum, g) => sum + g.rating, 0) / cityGyms.length).toFixed(1);
          const color = cityColors[index % cityColors.length];
          
          return (
            <a
              href={`/${stateSlug}/${citySlug}/`}
              class="group relative p-6 bg-gradient-to-br from-[#2d2d2d] to-[#1f1f1f] rounded-2xl border border-white/5 hover:border-white/20 transition-all duration-300 overflow-hidden"
              style={{ boxShadow: '0 8px 32px rgba(0,0,0,0.4)' }}
            >
              {/* Top accent line */}
              <div class="absolute top-0 left-0 right-0 h-1 opacity-0 group-hover:opacity-100 transition-opacity" style={{ background: color }}></div>
              
              {/* Hover glow */}
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style={{ background: `radial-gradient(circle at 50% 0%, ${color}10 0%, transparent 60%)` }}></div>
              
              <div class="mb-4 relative z-10">
                <h3 class="text-xl font-display font-bold text-white group-hover:text-white transition-colors">
                  {city}
                </h3>
              </div>
              
              <div class="flex flex-col gap-2 relative z-10">
                  <div class="flex items-center gap-2 text-white/40 text-sm">
                      <svg class="w-4 h-4" style={{ color }} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                      </svg>
                      <span class="font-mono">{cityGyms.length} {cityGyms.length === 1 ? 'Gym' : 'Gyms'}</span>
                  </div>
                  <div class="flex items-center gap-2 text-white/40 text-sm">
                      <svg class="w-4 h-4 text-[#ffea00]" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                      <span class="font-mono">{cityAvgRating} Average</span>
                  </div>
              </div>
              
              {/* Arrow indicator */}
              <svg class="absolute bottom-6 right-6 w-5 h-5 opacity-0 group-hover:opacity-100 transition-all transform translate-x-2 group-hover:translate-x-0 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Featured Gyms -->
    {featuredGyms.length > 0 && (
      <section class="mb-12">
        <h2 class="text-3xl font-display font-bold text-white mb-2">
          FEATURED GYMS IN {region.toUpperCase()}
        </h2>
        <p class="text-white/50 mb-6">
          These premium climbing facilities in {region} offer exceptional experiences with
          excellent route setting, comprehensive amenities, and welcoming communities.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredGyms.slice(0, 9).map((gym, index) => (
            <GymCard gym={gym} showCity={true} delay={index * 0.05} />
          ))}
        </div>
      </section>
    )}

    <!-- About Climbing in [State] -->
    <section class="mb-12 bg-[#1f1f1f] rounded-2xl border border-white/10 p-8" style={{ boxShadow: '0 8px 32px rgba(0,0,0,0.4)' }}>
      <h2 class="text-3xl font-display font-bold text-white mb-6">
        About Climbing in {region}
      </h2>
      <div class="prose max-w-none text-white/60 space-y-4">
        <p>
          {region} boasts a vibrant indoor climbing scene with {stateGyms.length} facilities spread
          across {cities.length} cities. The state's climbing gyms cater to everyone from first-time
          climbers to competitive athletes, offering diverse terrain, comprehensive training facilities,
          and supportive communities.
        </p>
      </div>
    </section>

    <!-- Statistics Grid -->
    <section class="mb-12">
      <h2 class="text-3xl font-display font-bold text-white mb-6">
        {region} Climbing Gym Statistics
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-[#1f1f1f] rounded-2xl border border-white/10 p-6" style={{ boxShadow: '0 8px 32px rgba(0,0,0,0.4)' }}>
          <h3 class="font-display font-bold text-white mb-4">Climbing Types</h3>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-white/60">Bouldering</span>
              <span class="font-mono font-bold text-[#00e676]">
                {stateGyms.filter(g => g.climbing_types?.includes('bouldering')).length} {gymLabel(stateGyms.filter(g => g.climbing_types?.includes('bouldering')).length)}
              </span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-white/60">Top Rope</span>
              <span class="font-mono font-bold text-[#2979ff]">
                {stateGyms.filter(g => g.climbing_types?.includes('top_rope')).length} {gymLabel(stateGyms.filter(g => g.climbing_types?.includes('top_rope')).length)}
              </span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-white/60">Lead Climbing</span>
              <span class="font-mono font-bold text-[#ff2d7a]">
                {stateGyms.filter(g => g.climbing_types?.includes('lead')).length} {gymLabel(stateGyms.filter(g => g.climbing_types?.includes('lead')).length)}
              </span>
            </div>
          </div>
        </div>

        <div class="bg-[#1f1f1f] rounded-2xl border border-white/10 p-6" style={{ boxShadow: '0 8px 32px rgba(0,0,0,0.4)' }}>
          <h3 class="font-display font-bold text-white mb-4">Amenities</h3>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-white/60">Showers</span>
              <span class="font-mono font-bold text-[#00e676]">
                {stateGyms.filter(g => g.amenities?.includes('showers')).length} {gymLabel(stateGyms.filter(g => g.amenities?.includes('showers')).length)}
              </span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-white/60">Cafe</span>
              <span class="font-mono font-bold text-[#2979ff]">
                {stateGyms.filter(g => g.amenities?.includes('cafe')).length} {gymLabel(stateGyms.filter(g => g.amenities?.includes('cafe')).length)}
              </span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-white/60">Sauna</span>
              <span class="font-mono font-bold text-[#ff2d7a]">
                {stateGyms.filter(g => g.amenities?.includes('sauna')).length} {gymLabel(stateGyms.filter(g => g.amenities?.includes('sauna')).length)}
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-12">
      <h2 class="text-3xl font-display font-bold text-white mb-6">
        Frequently Asked Questions
      </h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <details class="group bg-[#1f1f1f] rounded-2xl border border-white/10 overflow-hidden hover:border-white/20 transition-colors" style={{ boxShadow: '0 4px 16px rgba(0,0,0,0.3)' }}>
            <summary class="w-full flex items-center justify-between p-6 text-left cursor-pointer list-none">
              <span class="font-display font-semibold text-white pr-4">{faq.question}</span>
              <svg class="w-5 h-5 text-white/40 transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-white/60 leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Fresh Routes Announcement - California Only -->
    {region === 'California' && (
      <section class="my-16">
        <div class="bg-gradient-to-r from-[#00e676]/10 to-[#2979ff]/10 rounded-2xl p-8 md:p-12 border border-[#00e676]/20">
          <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
            <div class="max-w-2xl">
              <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#00e676]/20 text-[#00e676] text-sm font-mono font-bold mb-3">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                New in Los Angeles
              </div>
              <h3 class="text-2xl font-display font-bold text-white mb-2">Fresh Routes Tracker</h3>
              <p class="text-white/50">
                We're now tracking weekly route resets at Los Angeles climbing gyms. See which gyms have fresh sets this week.
              </p>
            </div>
            <a href="/fresh-routes-this-week/" class="btn-jug text-black flex-shrink-0 inline-flex items-center gap-2">
              View Fresh Routes
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      </section>
    )}

    <!-- CTA Section -->
    <section class="text-center bg-gradient-to-r from-[#00e676]/20 to-[#2979ff]/20 rounded-2xl p-12 border border-[#00e676]/20">
      <h2 class="text-3xl font-display font-bold text-white mb-4">
        Find Your Perfect Climbing Gym in {region}
      </h2>
      <p class="text-lg mb-8 text-white/60">
        Explore gyms in {cities.length} cities across {region} and start climbing today
      </p>
      <a
        href="#"
        onclick="window.scrollTo({top: 0, behavior: 'smooth'}); return false;"
        class="btn-jug text-black inline-flex items-center gap-2"
      >
        Browse Cities
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
        </svg>
      </a>
    </section>
  </div>
</BaseLayout>
