---
import BaseLayout from '../layouts/BaseLayout.astro';
import ClimbroTrackedLink from '../components/ClimbroTrackedLink.astro';
import { AFFILIATE_PRODUCTS, type Product } from '../data/affiliateProducts';

const title = "Recommended Climbing Gear | Indoor Climbing Gym";
const description = "Expert-curated climbing gear reviews. We've tested the best indoor climbing shoes, harnesses, and training equipment to help you climb harder and safer.";

// Group products by category
const productsByCategory = AFFILIATE_PRODUCTS.reduce((acc, product) => {
  const category = product.category || 'other';
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(product);
  return acc;
}, {} as Record<string, Product[]>);

const categoryTitles: Record<string, string> = {
  shoes: "Climbing Shoes",
  gear: "Essentials (Harnesses & Chalk)",
  training: "Training & Recovery",
  apparel: "Climbing Apparel",
  books: "Books & Guides"
};

const breadcrumbs = [
  { label: 'Home', url: '/' },
  { label: 'Recommended Gear', url: '/gear' },
];
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={breadcrumbs}
>
  <!-- Full-Width Hero Section -->
  <section class="w-full relative -mt-8 bg-gradient-to-br from-[#2979ff]/10 via-[#1a1a1a] to-[#00e676]/5 py-20 md:py-28 overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute top-0 left-0 w-full h-full opacity-10 bg-[radial-gradient(#2979ff_1px,transparent_1px)] [background-size:20px_20px]"></div>
    
    <div class="container mx-auto px-4 relative z-10 text-center">
      <span class="inline-block py-1 px-3 rounded-full bg-[#2979ff]/20 text-[#2979ff] font-bold text-sm tracking-wide uppercase mb-6 border border-[#2979ff]/30">
        Curated by Experts
      </span>
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 leading-tight font-display">
        Gear Up for the <span class="text-[#2979ff] relative inline-block">
          Send
          <svg class="absolute w-full h-3 -bottom-1 left-0 text-[#2979ff]/30" viewBox="0 0 100 10" preserveAspectRatio="none">
            <path d="M0 5 Q 50 10 100 5" stroke="currentColor" stroke-width="8" fill="none" />
          </svg>
        </span>
      </h1>
      <p class="text-xl text-white/70 max-w-2xl mx-auto leading-relaxed">
        Whether you're projecting V3 or training for 5.12, having the right gear makes all the difference. Here are our top picks for performance, comfort, and value.
      </p>
    </div>
  </section>

  <!-- Trust Signals / Value Props -->
  <section class="container mx-auto px-4 -mt-16 relative z-20 mb-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 bg-[#1f1f1f] rounded-2xl shadow-xl p-8 border border-white/10">
      <div class="flex flex-col items-center text-center p-4">
        <div class="w-12 h-12 bg-[#2979ff]/10 rounded-full flex items-center justify-center text-[#2979ff] mb-4">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <h3 class="font-bold text-white text-lg mb-2">Gym Tested</h3>
        <p class="text-sm text-white/60">Every product listed has been put to the test on plastic walls and gym mats.</p>
      </div>
      <div class="flex flex-col items-center text-center p-4 border-t md:border-t-0 md:border-l border-white/10">
        <div class="w-12 h-12 bg-[#2979ff]/10 rounded-full flex items-center justify-center text-[#2979ff] mb-4">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <h3 class="font-bold text-white text-lg mb-2">Best Value</h3>
        <p class="text-sm text-white/60">We prioritize gear that offers the best performance-to-price ratio for indoor climbers.</p>
      </div>
      <div class="flex flex-col items-center text-center p-4 border-t md:border-t-0 md:border-l border-white/10">
        <div class="w-12 h-12 bg-[#2979ff]/10 rounded-full flex items-center justify-center text-[#2979ff] mb-4">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
        </div>
        <h3 class="font-bold text-white text-lg mb-2">Science Based</h3>
        <p class="text-sm text-white/60">Training gear selected based on modern climbing physiology and recovery science.</p>
      </div>
    </div>
  </section>

  <div class="container mx-auto px-4">
    <div class="flex flex-col lg:flex-row gap-12 relative">
      <!-- Sticky Sidebar Navigation (Desktop) -->
      <aside class="hidden lg:block w-64 flex-shrink-0">
        <div class="sticky top-24 bg-[#1f1f1f] rounded-xl shadow-sm border border-white/10 p-6">
          <h3 class="font-bold text-white mb-4 uppercase text-xs tracking-wider">Categories</h3>
          <nav class="space-y-1">
            {Object.keys(productsByCategory).map((category) => (
              <a 
                href={`#${category}`} 
                class="flex items-center justify-between px-3 py-2 rounded-lg text-white/70 hover:text-[#2979ff] hover:bg-[#2979ff]/10 transition-colors group"
              >
                <span>{categoryTitles[category] || category}</span>
                <span class="text-xs bg-[#2d2d2d] text-white/60 px-2 py-0.5 rounded-full group-hover:bg-[#2979ff]/20 group-hover:text-[#2979ff] transition-colors">
                  {productsByCategory[category].length}
                </span>
              </a>
            ))}
          </nav>
          <div class="mt-8 pt-6 border-t border-white/10">
            <p class="text-xs text-white/50 leading-relaxed">
              We earn a commission if you make a purchase, at no extra cost to you.
            </p>
          </div>
        </div>
      </aside>

      <!-- Main Product Feed -->
      <div class="flex-1 space-y-20">
        {Object.entries(productsByCategory).map(([category, products]) => (
          <section id={category} class="scroll-mt-24">
            <div class="flex items-end justify-between mb-8 pb-4 border-b border-white/10">
              <div>
                <h2 class="text-3xl font-bold text-white mb-2">
                  {categoryTitles[category] || category}
                </h2>
                <p class="text-white/60">
                  {category === 'shoes' && "From aggressive boulders to comfy gym cruisers."}
                  {category === 'gear' && "Don't leave home without these essentials."}
                  {category === 'training' && "Level up your finger strength and power."}
                </p>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {products.map((product) => (
                product.affiliateProgram === 'climbro' ? (
                  <ClimbroTrackedLink
                    href={product.link}
                    label={product.name}
                    intent={product.affiliateIntent || product.id}
                    source={product.affiliateSource || 'gear-page'}
                    position={product.affiliatePosition || `${category}-grid`}
                    pageType="gear_page"
                    variant={product.affiliateVariant || 'product-card'}
                    class="group bg-[#1f1f1f] rounded-2xl shadow-sm border border-white/10 overflow-hidden hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full no-underline !no-underline"
                  >
                  <!-- Image Container with Badge -->
                  <div class="relative h-56 sm:h-72 bg-[#2d2d2d] p-4 sm:p-8 flex items-center justify-center overflow-hidden">
                    <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-[#2979ff]/5"></div>
                    <img 
                      src={product.imageUrl} 
                      alt={product.name} 
                      class="object-contain max-h-full max-w-full drop-shadow-md group-hover:scale-110 transition-transform duration-500 ease-out"
                      loading="lazy"
                    />
                    {product.badge && (
                      <span class="absolute top-4 left-4 bg-[#1f1f1f]/90 backdrop-blur-sm text-[#2979ff] text-xs font-bold px-3 py-1.5 rounded-full shadow-sm border border-[#2979ff]/30 flex items-center gap-1">
                        <svg class="w-3 h-3 text-[#ff9100]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                        {product.badge}
                      </span>
                    )}
                  </div>

                  <!-- Content -->
                  <div class="p-6 flex flex-col flex-grow">
                    <div class="flex justify-between items-start mb-2">
                      <h3 class="text-xl font-bold text-white group-hover:text-[#2979ff] transition-colors leading-tight">
                        {product.name}
                      </h3>
                    </div>
                    
                    <p class="text-white/70 text-sm mb-6 leading-relaxed flex-grow">
                      {product.description}
                    </p>
                    
                    <div class="mt-auto">
                      <div class="flex items-center justify-between p-4 bg-[#2d2d2d] rounded-xl group-hover:bg-[#2979ff]/10 transition-colors">
                        <div class="flex flex-col">
                          <span class="text-xs text-white/60 uppercase font-semibold">Price</span>
                          <span class="text-xl font-bold text-white">{product.price}</span>
                        </div>
                        <span class="w-10 h-10 bg-[#1f1f1f] rounded-full shadow-sm flex items-center justify-center text-[#2979ff] group-hover:bg-[#2979ff] group-hover:!text-white transition-all duration-300">
                          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                          </svg>
                        </span>
                      </div>
                    </div>
                  </div>
                  </ClimbroTrackedLink>
                ) : (
                  <a 
                    href={product.link}
                    target="_blank"
                    rel="noopener noreferrer sponsored"
                    class="group bg-[#1f1f1f] rounded-2xl shadow-sm border border-white/10 overflow-hidden hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full"
                  >
                  <!-- Image Container with Badge -->
                  <div class="relative h-56 sm:h-72 bg-[#2d2d2d] p-4 sm:p-8 flex items-center justify-center overflow-hidden">
                    <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-[#2979ff]/5"></div>
                    <img 
                      src={product.imageUrl} 
                      alt={product.name} 
                      class="object-contain max-h-full max-w-full drop-shadow-md group-hover:scale-110 transition-transform duration-500 ease-out"
                      loading="lazy"
                    />
                    {product.badge && (
                      <span class="absolute top-4 left-4 bg-[#1f1f1f]/90 backdrop-blur-sm text-[#2979ff] text-xs font-bold px-3 py-1.5 rounded-full shadow-sm border border-[#2979ff]/30 flex items-center gap-1">
                        <svg class="w-3 h-3 text-[#ff9100]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                        {product.badge}
                      </span>
                    )}
                  </div>

                  <!-- Content -->
                  <div class="p-6 flex flex-col flex-grow">
                    <div class="flex justify-between items-start mb-2">
                      <h3 class="text-xl font-bold text-white group-hover:text-[#2979ff] transition-colors leading-tight">
                        {product.name}
                      </h3>
                    </div>
                    
                    <p class="text-white/70 text-sm mb-6 leading-relaxed flex-grow">
                      {product.description}
                    </p>
                    
                    <div class="mt-auto">
                      <div class="flex items-center justify-between p-4 bg-[#2d2d2d] rounded-xl group-hover:bg-[#2979ff]/10 transition-colors">
                        <div class="flex flex-col">
                          <span class="text-xs text-white/60 uppercase font-semibold">Price</span>
                          <span class="text-xl font-bold text-white">{product.price}</span>
                        </div>
                        <span class="w-10 h-10 bg-[#1f1f1f] rounded-full shadow-sm flex items-center justify-center text-[#2979ff] group-hover:bg-[#2979ff] group-hover:!text-white transition-all duration-300">
                          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                          </svg>
                        </span>
                      </div>
                    </div>
                  </div>
                  </a>
                )
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>

    <!-- Mobile Footer Disclaimer -->
    <div class="lg:hidden mt-16 p-6 bg-[#1f1f1f] rounded-xl text-xs text-white/60 text-center leading-relaxed border border-white/10">
      <p>
        <strong class="text-white">Affiliate Disclosure:</strong> IndoorClimbingGym.com is a participant in the Amazon Services LLC Associates Program. 
        We earn from qualifying purchases at no extra cost to you.
      </p>
    </div>

    <section class="mt-16 mb-20">
      <div class="bg-gradient-to-br from-[#2979ff] to-[#1d5fd0] rounded-3xl p-8 md:p-12 text-center text-white shadow-2xl relative overflow-hidden">
        <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#ffffff_1px,transparent_1px)] [background-size:20px_20px]"></div>
        <div class="relative z-10 max-w-3xl mx-auto">
          <span class="inline-block py-1 px-3 rounded-full bg-white/15 border border-white/20 text-sm font-bold tracking-wide uppercase mb-5">
            For Climbing Brands
          </span>
          <h2 class="text-3xl md:text-4xl font-bold font-display mb-4">
            Want Your Climbing Product Featured Here?
          </h2>
          <p class="text-lg md:text-xl text-white/85 leading-relaxed mb-8">
            We partner with climbing brands to feature relevant gear in front of indoor climbers actively researching what to buy.
          </p>
          <a
            href="mailto:tim@indoorclimbinggym.com?subject=Gear%20Page%20Sponsorship"
            class="inline-flex items-center gap-2 bg-white text-[#1d5fd0] px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/90 transition-all shadow-lg hover:-translate-y-0.5"
          >
            Contact Us About Gear Sponsorship
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7l4 4 4-4m0 10H8a2 2 0 01-2-2V9a2 2 0 012-2h8a2 2 0 012 2v6a2 2 0 01-2 2z" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
