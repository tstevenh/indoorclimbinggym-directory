---
/**
 * Homepage - Dark Climbing Gym Theme
 * Replicated from app 2/ design
 * All SEO content preserved
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import GymCard from '../components/GymCard.astro';
import SearchBar from '../components/SearchBar.astro';
import AsSeenOn from '../components/AsSeenOn.astro';
import { generateOrganizationSchema, generateWebSiteSchema } from '../utils/schema';
import { fetchGyms } from '../config/api';
import { getStateCode, getStateSlug, getStateName } from '../utils/states';
import { addBrandSuffix } from '../utils/seo';

export const prerender = true;

const gyms = await fetchGyms();
const allFeaturedGyms = gyms.filter(g => g.featured);
const topRatedGyms = [...gyms].sort((a, b) => b.rating - a.rating);
const displayGyms = allFeaturedGyms.length >= 3 ? allFeaturedGyms.slice(0, 6) : topRatedGyms.slice(0, 6);

const stateCounts = gyms.reduce((acc, gym) => {
  const state = gym.region?.toLowerCase();
  if (state) acc[state] = (acc[state] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const topStates = Object.entries(stateCounts)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 12)
  .map(([state, count]) => ({ state, count }));

// Get top cities by gym count for footer
const cityGymCounts = gyms.reduce((acc, gym) => {
  const key = `${gym.city}-${gym.region}`;
  if (!acc[key]) {
    acc[key] = { city: gym.city, region: gym.region, count: 0, slug: gym.slug };
  }
  acc[key].count++;
  return acc;
}, {} as Record<string, { city: string; region: string; count: number; slug: string }>);

const topCities = Object.values(cityGymCounts)
  .sort((a, b) => b.count - a.count)
  .slice(0, 18);

const uniqueCities = new Map();
gyms.forEach(gym => {
  const key = `${gym.city}-${gym.region}`;
  if (!uniqueCities.has(key)) {
    uniqueCities.set(key, { city: gym.city, region: gym.region, slug: gym.slug });
  }
});
const cities = Array.from(uniqueCities.values());

const topCategories = [
  { name: 'Best Bouldering Gyms', slug: 'best-bouldering-climbing-gyms', description: 'Top-rated facilities focused on bouldering excellence', count: gyms.filter(g => g.climbing_types?.includes('bouldering')).length, color: '#ff2d7a' },
  { name: 'For Beginners', slug: 'best-climbing-gyms-for-beginners', description: 'Welcoming gyms perfect for first-time climbers', count: gyms.filter(g => g.beginner_friendly).length, color: '#00e676' },
  { name: 'Best Lead Climbing', slug: 'best-lead-climbing-gyms', description: 'Top facilities specializing in lead climbing', count: gyms.filter(g => g.climbing_types?.includes('lead')).length, color: '#2979ff' },
  { name: 'Affordable Gyms', slug: 'affordable-climbing-gyms', description: 'Budget-friendly climbing gyms with great value', count: gyms.filter(g => g.day_pass_price_local && g.day_pass_price_local <= 20).length, color: '#ffea00' },
  { name: 'With Sauna', slug: 'climbing-gyms-with-sauna', description: 'Recovery-focused gyms with sauna amenities', count: gyms.filter(g => g.amenities?.includes('sauna')).length, color: '#ff1744' },
  { name: 'Kids Zone', slug: 'climbing-gyms-with-kids-zone', description: 'Family-friendly gyms with dedicated kids areas', count: gyms.filter(g => g.amenities?.includes('kids_zone')).length, color: '#ff9100' },
];

const orgSchema = generateOrganizationSchema();
const websiteSchema = generateWebSiteSchema();
const combinedSchema = [orgSchema, websiteSchema];

const totalGyms = gyms.length;
const uniqueStates = [...new Set(gyms.map(g => g.region))].length;

const baseTitle = `Find ${totalGyms}+ Climbing Gyms Near You`;
const title = addBrandSuffix(baseTitle, 'IndoorClimbingGym');
const description = `Search ${totalGyms}+ climbing gyms in ${uniqueStates} states. Compare ratings, prices & amenities. Bouldering, lead & top rope. Free gym finder with reviews.`;
---

<BaseLayout title={title} description={description} schema={combinedSchema}>
  <Fragment slot="head">
    <meta name="impact-site-verification" value="bab4af13-beab-4e5b-b1a9-66b2af7b9921" />
  </Fragment>

  <!-- Hero Section - Fit one screen -->
  <section class="relative h-[calc(100vh-80px)] min-h-[600px] max-h-[750px] flex flex-col overflow-hidden bg-[#1a1a1a]">
    <!-- Background holds image -->
    <div class="absolute inset-0 z-0">
      <img
        src="/holds-hero.jpg"
        alt=""
        class="w-full h-full object-cover opacity-40"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#1a1a1a] via-transparent to-[#1a1a1a]"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#1a1a1a]/80 via-transparent to-[#1a1a1a]/80"></div>
    </div>

    <!-- Subtle gradient orbs (static, no animation) -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-[-20%] right-[-10%] w-[600px] h-[600px] bg-[#ff2d7a] rounded-full mix-blend-screen filter blur-3xl opacity-5"></div>
      <div class="absolute top-[20%] left-[-10%] w-[400px] h-[400px] bg-[#00e676] rounded-full mix-blend-screen filter blur-3xl opacity-5"></div>
      <div class="absolute bottom-[-10%] right-[20%] w-[500px] h-[500px] bg-[#2979ff] rounded-full mix-blend-screen filter blur-3xl opacity-5"></div>
    </div>

    <!-- Main content -->
    <div class="relative z-10 flex-1 flex flex-col justify-center px-4 sm:px-6 lg:px-8 pt-2 pb-4">
      <div class="max-w-5xl mx-auto w-full">
        <!-- Eyebrow -->
        <div class="mb-2">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-[#2d2d2d]/80 backdrop-blur-sm rounded-full border border-white/10">
            <span class="w-2 h-2 rounded-full bg-[#00e676]"></span>
            <span class="text-xs text-white/70 font-mono">The #1 Climbing Gym Directory</span>
          </span>
        </div>

        <!-- Main headline - SEO preserved -->
        <h1 class="font-display font-bold text-5xl sm:text-6xl lg:text-8xl text-white mb-2 leading-[0.9] tracking-tight text-glow">
          FIND YOUR
          <br />
          <span class="relative inline-block">
            <span class="bg-gradient-to-r from-[#00e676] via-[#2979ff] to-[#ff2d7a] bg-clip-text text-transparent">
              NEXT CLIMB
            </span>
            <svg class="absolute -bottom-1 left-0 w-full h-3" viewBox="0 0 400 20" fill="none">
              <path d="M0 10 Q100 0 200 10 T400 10" stroke="url(#lineGradient)" stroke-width="3" fill="none" stroke-linecap="round" class="route-line"/>
              <defs>
                <linearGradient id="lineGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#00e676" />
                  <stop offset="50%" stop-color="#2979ff" />
                  <stop offset="100%" stop-color="#ff2d7a" />
                </linearGradient>
              </defs>
            </svg>
          </span>
        </h1>

        <!-- Subheadline - SEO preserved -->
        <p class="text-xl sm:text-2xl text-white/60 mb-3 max-w-xl">
          The complete directory of indoor climbing gyms across America. 
          Search by location, grade, or climbing style.
        </p>

        <!-- Search bar -->
        <div class="mb-6 max-w-2xl">
          <SearchBar large={true} placeholder="Enter city, state, or gym name..." />
        </div>

        <!-- Stats -->
        <div class="flex items-center gap-8 sm:gap-12">
          <div class="text-center">
            <div class="font-mono font-bold text-4xl sm:text-5xl text-[#00e676]">{totalGyms}</div>
            <div class="text-white/40 text-xs font-mono tracking-widest mt-1">GYMS</div>
          </div>
          <div class="text-center">
            <div class="font-mono font-bold text-4xl sm:text-5xl text-[#2979ff]">{cities.length}</div>
            <div class="text-white/40 text-xs font-mono tracking-widest mt-1">CITIES</div>
          </div>
          <div class="text-center">
            <div class="font-mono font-bold text-4xl sm:text-5xl text-[#ff2d7a]">{uniqueStates}</div>
            <div class="text-white/40 text-xs font-mono tracking-widest mt-1">STATES</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex flex-col items-center gap-0.5">
      <span class="text-white/30 text-[10px] font-mono">SCROLL TO EXPLORE</span>
      <svg class="w-4 h-4 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </section>

  <!-- Social Proof / As Seen On -->
  <AsSeenOn />

  {/* Featured Gyms Section - Only show if there are featured gyms */}
  {allFeaturedGyms.length > 0 && (
  <section class="relative py-12 lg:py-16 bg-[#1a1a1a] overflow-hidden">
    <!-- Background texture -->
    <div class="absolute inset-0 opacity-30">
      <div class="w-full h-full chalk-texture"></div>
    </div>
    
    <!-- Route lines SVG -->
    <svg class="absolute inset-0 w-full h-full pointer-events-none opacity-20" viewBox="0 0 1200 800" fill="none" preserveAspectRatio="none">
      <defs>
        <linearGradient id="routeGradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#00e676" />
          <stop offset="50%" stop-color="#2979ff" />
          <stop offset="100%" stop-color="#ff2d7a" />
        </linearGradient>
      </defs>
      <path d="M100 150 Q300 100 500 200 T900 180 T1100 250" stroke="url(#routeGradient)" stroke-width="2" fill="none" stroke-linecap="round" stroke-dasharray="8 4" class="route-line"/>
      <path d="M200 400 Q400 350 600 420 T1000 380" stroke="url(#routeGradient)" stroke-width="2" fill="none" stroke-linecap="round" stroke-dasharray="8 4" class="route-line" style="animation-delay: 0.3s"/>
      <path d="M150 650 Q350 600 550 680 T950 640" stroke="url(#routeGradient)" stroke-width="2" fill="none" stroke-linecap="round" stroke-dasharray="8 4" class="route-line" style="animation-delay: 0.6s"/>
    </svg>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section header -->
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
        <div>
          <span class="text-[#00e676] text-sm font-mono tracking-widest mb-1 block">THE WALL</span>
          <h2 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl text-white">
            FEATURED
            <br />
            <span class="text-white/40">GYMS</span>
          </h2>
        </div>
        
        <a href="/search/" class="inline-flex items-center gap-2 text-white/60 hover:text-[#00e676] transition-colors font-mono">
          VIEW ALL ROUTES
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
      
      <!-- Gym cards grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {displayGyms.map((gym, index) => (
          <div class={index % 2 === 1 ? 'lg:mt-8' : ''}>
            <GymCard gym={gym} delay={index * 0.1} />
          </div>
        ))}
      </div>
      
      <!-- Bottom CTA -->
      <div class="mt-10 text-center">
        <a href="/search/" class="btn-jug text-black inline-flex items-center gap-2 text-sm">
          EXPLORE ALL {totalGyms} GYMS
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
  )}

  <!-- Leaderboard CTA Section -->
  <section class="relative py-24 bg-[#1a1a1a] overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#00e676]/5 via-transparent to-[#2979ff]/5"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left content -->
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-[#ffea00]/10 rounded-full mb-6">
            <svg class="w-4 h-4 text-[#ffea00]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
            </svg>
            <span class="text-sm font-mono text-[#ffea00]">COMMUNITY COMPETITION</span>
          </div>
          
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-white mb-4">
            CLIMB THE
            <br />
            <span class="text-[#ffea00]">LEADERBOARD</span>
          </h2>
          
          <p class="text-white/60 text-lg mb-8 max-w-md">
            Log your gym visits, compete with other cities, and track your climbing progress. Join the monthly competition!
          </p>
          
          <div class="flex flex-wrap gap-4">
            <a href="/leaderboard/" class="btn-jug text-black inline-flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
              </svg>
              VIEW LEADERBOARD
            </a>
            <a href={`${import.meta.env.PUBLIC_DASHBOARD_URL || 'https://dashboard.indoorclimbinggym.com'}/signup`} class="btn-crimp text-white inline-flex items-center gap-2">
              JOIN NOW
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
        
        <!-- Right - Preview cards showing what leaderboard offers -->
        <div class="space-y-4">
          <div class="text-white/40 text-sm font-mono mb-4">HOW IT WORKS</div>
          
          <div class="flex items-center gap-4 p-4 bg-[#2d2d2d] rounded-xl" style={{ boxShadow: '0 4px 16px rgba(0,0,0,0.3)' }}>
            <div class="w-10 h-10 flex items-center justify-center font-mono font-bold rounded-lg bg-[#ffea00] text-black">
              1
            </div>
            <div class="flex-1">
              <div class="font-display font-bold text-white">Log Your Sessions</div>
              <div class="text-white/40 text-sm font-mono">Track every gym visit</div>
            </div>
          </div>
          
          <div class="flex items-center gap-4 p-4 bg-[#2d2d2d] rounded-xl" style={{ boxShadow: '0 4px 16px rgba(0,0,0,0.3)' }}>
            <div class="w-10 h-10 flex items-center justify-center font-mono font-bold rounded-lg bg-white/20 text-white">
              2
            </div>
            <div class="flex-1">
              <div class="font-display font-bold text-white">Compete With Cities</div>
              <div class="text-white/40 text-sm font-mono">City vs City rankings</div>
            </div>
          </div>
          
          <div class="flex items-center gap-4 p-4 bg-[#2d2d2d] rounded-xl" style={{ boxShadow: '0 4px 16px rgba(0,0,0,0.3)' }}>
            <div class="w-10 h-10 flex items-center justify-center font-mono font-bold rounded-lg bg-[#ff9100] text-black">
              3
            </div>
            <div class="flex-1">
              <div class="font-display font-bold text-white">Earn Rankings</div>
              <div class="text-white/40 text-sm font-mono">Climb the explorer board</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- Why Use Section -->
  <section class="relative py-24 bg-[#1a1a1a]">
    <div class="absolute inset-0 opacity-15">
      <div class="w-full h-full chalk-texture"></div>
    </div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-[#00e676] text-sm font-mono tracking-widest mb-2 block">WHY CLIMBERS CHOOSE US</span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-white">
          BUILT BY CLIMBERS,
          <br />
          <span class="text-white/40">FOR CLIMBERS</span>
        </h2>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: 'database', title: 'COMPLETE DIRECTORY', description: `${totalGyms}+ gyms across ${cities.length} cities. From bouldering caves to full-service facilities.`, color: '#ff2d7a' },
          { icon: 'info', title: 'DETAILED INFO', description: 'Hours, prices, amenities, directions—everything you need to plan your session.', color: '#2979ff' },
          { icon: 'sliders', title: 'SMART FILTERS', description: 'Find by climbing type, grade, amenities, budget, location. Exactly what you need.', color: '#00e676' },
          { icon: 'book', title: 'EXPERT GUIDES', description: 'Techniques, gear, etiquette, training tips from experienced climbers.', color: '#ffea00' },
        ].map((feature, index) => (
          <div class="relative p-6 bg-gradient-to-br from-[#2d2d2d] to-[#1f1f1f] rounded-2xl group hover:-translate-y-2 transition-transform" style={{ boxShadow: '0 8px 32px rgba(0,0,0,0.4)' }}>
            <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-xl" style={{ background: `radial-gradient(circle, ${feature.color}20 0%, transparent 70%)` }}></div>
            <div class="relative w-14 h-14 flex items-center justify-center rounded-xl mb-5" style={{ background: `${feature.color}15`, boxShadow: `0 4px 16px ${feature.color}20` }}>
              {feature.icon === 'database' && (
                <svg class="w-7 h-7" style={{ color: feature.color }} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>
                </svg>
              )}
              {feature.icon === 'info' && (
                <svg class="w-7 h-7" style={{ color: feature.color }} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              )}
              {feature.icon === 'sliders' && (
                <svg class="w-7 h-7" style={{ color: feature.color }} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
                </svg>
              )}
              {feature.icon === 'book' && (
                <svg class="w-7 h-7" style={{ color: feature.color }} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
              )}
            </div>
            <h3 class="relative font-display font-bold text-white mb-2">{feature.title}</h3>
            <p class="relative text-white/50 text-sm leading-relaxed">{feature.description}</p>
            <div class="absolute bottom-0 left-6 right-6 h-0.5 rounded-full opacity-0 group-hover:opacity-100 transition-opacity" style={{ background: feature.color }}></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Browse by State Section -->
  <section class="relative py-24 bg-[#1a1a1a] border-y border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12">
        <div>
          <span class="text-[#2979ff] text-sm font-mono tracking-widest mb-2 block">EXPLORE BY REGION</span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-white">
            BROWSE
            <br />
            <span class="text-white/40">BY STATE</span>
          </h2>
        </div>
        
        <a href="/states/" class="inline-flex items-center gap-2 text-white/60 hover:text-[#2979ff] transition-colors font-mono">
          ALL {uniqueStates} STATES
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
        {topStates.map(({ state, count }, index) => {
          const stateCode = getStateCode(state);
          const stateSlug = getStateSlug(state);
          const fullName = getStateName(state);
          const colors = ['#ff2d7a', '#00e676', '#2979ff', '#ffea00', '#ff9100', '#e040fb'];
          const color = colors[index % colors.length];
          
          return (
            <a
              href={`/${stateSlug}/`}
              class="group relative p-5 bg-[#2d2d2d] rounded-xl text-center hover:-translate-y-1 hover:scale-[1.02] transition-all"
              style={{ boxShadow: '0 4px 16px rgba(0,0,0,0.3)' }}
            >
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-full mb-3 font-mono font-bold text-lg" style={{ background: `${color}20`, color: color, boxShadow: `0 4px 16px ${color}20` }}>
                {stateCode}
              </div>
              <div class="font-display font-semibold text-white mb-1 group-hover:text-white transition-colors">{fullName}</div>
              <div class="flex items-center justify-center gap-1 text-white/40 text-sm">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
