---
/**
 * BaseLayout
 * Foundation layout for all pages with comprehensive SEO meta tags and schema markup
 * Updated with dark climbing gym theme
 */
import '../styles/global.css';
import { fetchGyms } from '../config/api';
import { getStateCode, getStateSlug } from '../utils/states';
import SpeedInsights from '@vercel/speed-insights/astro';
import Analytics from '@vercel/analytics/astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  keywords?: string[];
  noindex?: boolean;
  nofollow?: boolean;
  schema?: any;
  breadcrumbs?: Array<{ label: string; url: string }>;
  prevUrl?: string;
  nextUrl?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
  articleTags?: string[];
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://www.indoorclimbinggym.com/og-default.jpg',
  ogType = 'website',
  keywords = [],
  noindex = false,
  nofollow = false,
  schema,
  breadcrumbs,
  prevUrl,
  nextUrl,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleSection,
  articleTags,
} = Astro.props;

// Fetch gyms for navigation
let gymsData = [];
try {
  gymsData = await fetchGyms();
} catch (e) {
  console.warn('BaseLayout: failed to fetch gyms');
  gymsData = [];
}

// Calculate top 20 states
const stateCounts: Record<string, number> = {};
gymsData.forEach(gym => {
  const region = gym.region?.trim();
  if (region) {
    stateCounts[region] = (stateCounts[region] || 0) + 1;
  }
});

const top22States = Object.entries(stateCounts)
  .sort(([,a], [,b]) => b - a)
  .slice(0, 22);

// Calculate top 20 cities
const cityCounts: Record<string, { count: number; city: string; region: string; slug: string }> = {};
gymsData.forEach(gym => {
  const city = gym.city?.trim();
  const region = gym.region?.trim();
  if (city && region) {
    const key = `${city}, ${region}`;
    if (!cityCounts[key]) {
      cityCounts[key] = {
        count: 0,
        city,
        region,
        slug: city.toLowerCase().replace(/\s+/g, '-')
      };
    }
    cityCounts[key].count++;
  }
});

const top22Cities = Object.values(cityCounts)
  .sort((a, b) => b.count - a.count)
  .slice(0, 22);

// Build canonical URL
const siteUrl = 'https://www.indoorclimbinggym.com';

let canonicalURL: string;

if (canonical && typeof canonical === 'string') {
  canonicalURL = canonical.endsWith('/') ? canonical : canonical + '/';
} else {
  let path = Astro.url.pathname;
  if (!path.endsWith('/') && !path.includes('.')) {
    path = path + '/';
  }
  canonicalURL = `${siteUrl}${path}`;
}

const finalTitle = title.length > 60 ? title.substring(0, 57) + '...' : title;
const finalDescription = description.length > 160 ? description.substring(0, 157) + '...' : description;

const robotsDirectives = [];
if (noindex) robotsDirectives.push('noindex');
if (nofollow) robotsDirectives.push('nofollow');
const robots = robotsDirectives.length > 0 ? robotsDirectives.join(', ') : 'index, follow';

let breadcrumbSchema = null;
if (breadcrumbs && breadcrumbs.length > 0) {
  breadcrumbSchema = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((crumb, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: crumb.label,
      item: crumb.url,
    })),
  };
}

const navLinks = [
  { name: 'Search', href: '/search/', color: '#00e676' },
  { name: 'States', href: '/states/', color: '#2979ff' },
  { name: 'Categories', href: '/categories/', color: '#ff2d7a' },
  { name: 'Leaderboard', href: '/leaderboard/', color: '#ffea00' },
  { name: 'Blog', href: '/blog/', color: '#ff9100' },
];
---

<!doctype html>
<html lang="en" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{finalTitle}</title>
    <meta name="title" content={finalTitle} />
    <meta name="description" content={finalDescription} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <meta name="robots" content={robots} />

    <!-- Google Search Console Verification -->
    <meta name="google-site-verification" content="T-zPHFE-oDE3mQ2g5Fqn4IwfQZUUFOjOAJIC7cIAP7U" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Pagination Links (SEO) -->
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="IndoorClimbingGym" />

    <!-- Article-specific Open Graph tags -->
    {ogType === 'article' && articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
    {ogType === 'article' && articleModifiedTime && <meta property="article:modified_time" content={articleModifiedTime} />}
    {ogType === 'article' && articleAuthor && <meta property="article:author" content={articleAuthor} />}
    {ogType === 'article' && articleSection && <meta property="article:section" content={articleSection} />}
    {ogType === 'article' && articleTags && articleTags.map(tag => <meta property="article:tag" content={tag} />)}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={finalTitle} />
    <meta property="twitter:description" content={finalDescription} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/logo.svg" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />

    <!-- JSON-LD Structured Data -->
    {Array.isArray(schema)
      ? schema.map((s) => (
          <script type="application/ld+json" set:html={JSON.stringify(s)} />
        ))
      : schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
    {
      breadcrumbSchema && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(breadcrumbSchema)}
        />
      )
    }

    <!-- Vercel Speed Insights -->
    <SpeedInsights />

    <!-- Vercel Web Analytics -->
    <Analytics />

    <!-- Google Analytics -->
    <script type="text/partytown" src="https://www.googletagmanager.com/gtag/js?id=G-KQJE0F08ER"></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        'analytics_storage': 'granted',
        'ad_storage': 'granted',
        'ad_user_data': 'granted',
        'ad_personalization': 'granted'
      });
      gtag('js', new Date());
      gtag('config', 'G-KQJE0F08ER');
    </script>
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-[#1a1a1a] text-[#f5f5f0] antialiased overflow-x-hidden">
    <!-- Skip to main content -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-[#00e676] focus:text-[#1a1a1a] focus:px-4 focus:py-2 focus:rounded-lg focus:font-bold">
      Skip to main content
    </a>

    <!-- Header -->
    <header id="main-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav class="flex items-center justify-between h-20">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 group">
            <img 
              src="/logo.svg" 
              alt="Indoor Climbing Gym" 
              class="w-10 h-10"
              style="filter: drop-shadow(0 4px 8px rgba(0,0,0,0.4));"
            />
            <div class="hidden sm:block">
              <span class="font-display font-bold text-white text-base leading-tight block">
                Indoor
              </span>
              <span class="font-display font-bold text-[#00e676] text-base leading-tight block -mt-0.5">
                Climbing Gym
              </span>
            </div>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden lg:flex items-center gap-2">
            {navLinks.map((link, i) => (
              <a
                key={link.name}
                href={link.href}
                class="relative px-4 py-2 font-display font-semibold text-sm text-white/80 hover:text-white transition-all duration-200 hover:-translate-y-0.5"
                style={{
                  background: 'linear-gradient(145deg, #2d2d2d, #1f1f1f)',
                  borderRadius: i % 2 === 0 ? '30% 70% 70% 30% / 30% 30% 70% 70%' : '8px 20px 8px 20px',
                  boxShadow: '0 4px 0 #1a1a1a, 0 6px 12px rgba(0,0,0,0.4), inset 0 1px 2px rgba(255,255,255,0.05)',
                }}
              >
                {link.name}
              </a>
            ))}
            <a
              href={import.meta.env.PUBLIC_DASHBOARD_URL || 'https://dashboard.indoorclimbinggym.com'}
              class="relative ml-2 px-4 py-2 font-display font-semibold text-sm text-black bg-[#00e676] hover:bg-[#00c853] transition-all duration-200 hover:-translate-y-0.5"
              style={{
                borderRadius: '30% 70% 70% 30% / 30% 30% 70% 70%',
                boxShadow: '0 4px 0 #009624, 0 6px 12px rgba(0,0,0,0.4)',
              }}
            >
              Sign In
            </a>
          </div>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-button"
            type="button"
            class="lg:hidden relative w-12 h-12 flex items-center justify-center"
            style={{
              background: 'linear-gradient(145deg, #2d2d2d, #1f1f1f)',
              borderRadius: '50%',
              boxShadow: '0 4px 0 #1a1a1a, 0 6px 16px rgba(0,0,0,0.4)',
            }}
            aria-label="Open menu"
          >
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-40 lg:hidden hidden">
      <div id="mobile-menu-panel" class="absolute right-0 top-0 bottom-0 w-80 bg-[#1a1a1a] border-l border-white/10 p-6 transform translate-x-full transition-transform duration-300">
        <div class="flex items-center justify-between mb-8">
          <span class="font-display font-bold text-white">MENU</span>
          <button
            id="mobile-menu-close"
            class="w-10 h-10 flex items-center justify-center rounded-full bg-white/5"
          >
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <div class="space-y-3">
          {navLinks.map((link) => (
            <a
              key={link.name}
              href={link.href}
              class="block px-5 py-4 bg-[#2d2d2d] rounded-xl text-white font-display font-semibold"
              style={{ borderLeft: `4px solid ${link.color}` }}
            >
              {link.name}
            </a>
          ))}
          <a
            href={import.meta.env.PUBLIC_DASHBOARD_URL || 'https://dashboard.indoorclimbinggym.com'}
            class="block px-5 py-4 bg-[#00e676] rounded-xl text-black font-display font-bold text-center"
          >
            Sign In
          </a>
        </div>

        <!-- Stats in mobile menu -->
        <div class="mt-8 pt-8 border-t border-white/10">
          <div class="grid grid-cols-3 gap-4 text-center">
            <div>
              <div class="font-mono font-bold text-2xl text-[#00e676]">{gymsData.length || 779}</div>
              <div class="text-xs text-white/40 font-mono">GYMS</div>
            </div>
            <div>
              <div class="font-mono font-bold text-2xl text-[#2979ff]">{(gymsData.length && [...new Set(gymsData.map(g => g.city))].length) || 553}</div>
              <div class="text-xs text-white/40 font-mono">CITIES</div>
            </div>
            <div>
              <div class="font-mono font-bold text-2xl text-[#ff2d7a]">{(gymsData.length && [...new Set(gymsData.map(g => g.region))].length) || 51}</div>
              <div class="text-xs text-white/40 font-mono">STATES</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Main content -->
    <main id="main-content" class="pt-20">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="relative bg-[#0f0f0f] border-t border-white/5">
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12">
          <!-- Brand -->
          <div class="lg:col-span-2">
            <a href="/" class="inline-flex items-center gap-3 mb-6">
              <img 
                src="/logo.svg" 
                alt="Indoor Climbing Gym" 
                class="w-12 h-12"
                style="filter: drop-shadow(0 4px 8px rgba(0,0,0,0.4));"
              />
              <div>
                <span class="font-display font-bold text-white text-base leading-tight block">Indoor</span>
                <span class="font-display font-bold text-[#00e676] text-base leading-tight block -mt-0.5">Climbing Gym</span>
              </div>
            </a>
            <p class="text-white/40 mb-6 max-w-sm">
              The complete directory of indoor climbing gyms across America. Find your next climb.
            </p>
            <a href="mailto:tim@indoorclimbinggym.com" class="inline-flex items-center gap-2 text-white/40 hover:text-[#00e676] transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <span class="text-sm font-mono">tim@indoorclimbinggym.com</span>
            </a>
          </div>
          
          <!-- Explore -->
          <div>
            <h3 class="font-display font-bold text-white mb-4 text-sm tracking-wider">EXPLORE</h3>
            <ul class="space-y-3">
              <li><a href="/search/" class="text-white/40 hover:text-[#00e676] transition-colors text-sm">Search</a></li>
              <li><a href="/states/" class="text-white/40 hover:text-[#00e676] transition-colors text-sm">States</a></li>
              <li><a href="/categories/" class="text-white/40 hover:text-[#00e676] transition-colors text-sm">Categories</a></li>
              <li><a href="/leaderboard/" class="text-white/40 hover:text-[#00e676] transition-colors text-sm">Leaderboard</a></li>
            </ul>
          </div>
          
          <!-- Resources -->
          <div>
            <h3 class="font-display font-bold text-white mb-4 text-sm tracking-wider">RESOURCES</h3>
            <ul class="space-y-3">
              <li><a href="/blog/" class="text-white/40 hover:text-[#2979ff] transition-colors text-sm">Blog</a></li>
              <li><a href="/tools/" class="text-white/40 hover:text-[#2979ff] transition-colors text-sm">Tools</a></li>
              <li><a href="/studies/" class="text-white/40 hover:text-[#2979ff] transition-colors text-sm">Studies</a></li>
              <li><a href="/gear/" class="text-white/40 hover:text-[#2979ff] transition-colors text-sm">Gear</a></li>
            </ul>
          </div>
          
          <!-- Company -->
          <div>
            <h3 class="font-display font-bold text-white mb-4 text-sm tracking-wider">COMPANY</h3>
            <ul class="space-y-3">
              <li><a href="/about/" class="text-white/40 hover:text-[#ff2d7a] transition-colors text-sm">About</a></li>
              <li><a href="/contact/" class="text-white/40 hover:text-[#ff2d7a] transition-colors text-sm">Contact</a></li>
              <li><a href="/privacy/" class="text-white/40 hover:text-[#ff2d7a] transition-colors text-sm">Privacy</a></li>
              <li><a href="/terms/" class="text-white/40 hover:text-[#ff2d7a] transition-colors text-sm">Terms</a></li>
            </ul>
          </div>
        </div>
        
        {/* Popular States */}
        <div class="border-t border-white/5 mt-12 pt-8">
          <h4 class="text-white/50 text-[10px] font-mono uppercase tracking-wider mb-4">Popular States</h4>
          <div class="flex flex-wrap gap-x-4 gap-y-1.5">
            {top22States.map(([state, count]) => {
              const stateSlug = state.toLowerCase().replace(/\s+/g, '-');
              return (
                <a 
                  href={`/${stateSlug}/`}
                  class="text-white/40 hover:text-[#00e676] transition-colors text-xs"
                >
                  Indoor Climbing Gym in {state}
                </a>
              );
            })}
          </div>
        </div>

        {/* Popular Cities */}
        <div class="border-t border-white/5 mt-8 pt-8">
          <h4 class="text-white/50 text-[10px] font-mono uppercase tracking-wider mb-4">Popular Cities</h4>
          <div class="flex flex-wrap gap-x-4 gap-y-1.5">
            {top22Cities.map((city) => {
              const stateSlug = city.region.toLowerCase().replace(/\s+/g, '-');
              const citySlug = city.city.toLowerCase().replace(/\s+/g, '-');
              return (
                <a 
                  href={`/${stateSlug}/${citySlug}/`}
                  class="text-white/40 hover:text-[#2979ff] transition-colors text-xs"
                >
                  Indoor Climbing Gym in {city.city}
                </a>
              );
            })}
          </div>
        </div>

        {/* Bottom bar with badges */}
        <div class="border-t border-white/5 mt-8 pt-8 flex flex-col lg:flex-row items-center justify-between gap-6">
          <p class="text-white/30 text-sm font-mono">
            © {new Date().getFullYear()} INDOORCLIMBINGGYM. ALL RIGHTS RESERVED.
          </p>
          
          {/* Badges */}
          <div class="flex flex-wrap items-center justify-center gap-3">
            <a href="https://startupfa.me/s/indoorclimbinggym?utm_source=www.indoorclimbinggym.com" target="_blank" class="h-6 flex items-center justify-center">
              <img src="https://startupfa.me/badges/featured-badge-small.webp" alt="IndoorClimbingGym - Featured on Startup Fame" width="150" height="24" class="max-h-4 w-auto object-contain" />
            </a>
            <a href="https://trylaunch.ai/launch/indoor-climbing-gym" target="_blank" rel="dofollow" class="h-6 flex items-center justify-center px-1.5 bg-white rounded border border-gray-200 hover:border-gray-300 transition-all">
              <img src="https://trylaunch.ai/badges/badge-color.svg" alt="Launch" height="22" class="max-h-3.5 w-auto object-contain" />
            </a>
            <a href="https://shipybara.com/projects/indoor-climbing-gym" target="_blank" rel="noopener" class="h-6 flex items-center justify-center">
              <img src="https://shipybara.com/images/badges/shipybara-badge-light.svg" alt="Featured on Shipybara" width="100" height="36" class="max-h-4 w-auto object-contain" />
            </a>
            <a href="https://foundrlist.com/product/indoorclimbinggym" target="_blank" rel="noopener noreferrer" class="h-6 flex items-center justify-center">
              <img src="https://foundrlist.com/api/badge/indoorclimbinggym" alt="Live on FoundrList" width="120" height="48" class="max-h-4 w-auto object-contain" />
            </a>
          </div>
        </div>

        {/* Affiliate Disclosure */}
        <div class="border-t border-white/5 mt-8 pt-8">
          <p class="text-white/30 text-xs text-center max-w-4xl mx-auto">
            <span class="font-semibold">Affiliate Disclosure:</span> IndoorClimbingGym.com is a participant in the Amazon Services LLC Associates Program, an affiliate advertising program designed to provide a means for sites to earn advertising fees by advertising and linking to Amazon.com.
          </p>
        </div>
      </div>
    </footer>

    <!-- Cookie Consent -->
    <CookieConsent />

    <!-- Mobile menu script -->
    <script>
      const menuButton = document.getElementById('mobile-menu-button');
      const mobileMenu = document.getElementById('mobile-menu');
      const mobileMenuPanel = document.getElementById('mobile-menu-panel');
      const closeButton = document.getElementById('mobile-menu-close');

      function openMenu() {
        if (mobileMenu && mobileMenuPanel) {
          mobileMenu.classList.remove('hidden');
          setTimeout(() => {
            mobileMenuPanel.classList.remove('translate-x-full');
          }, 10);
          document.body.style.overflow = 'hidden';
        }
      }

      function closeMenu() {
        if (mobileMenu && mobileMenuPanel) {
          mobileMenuPanel.classList.add('translate-x-full');
          setTimeout(() => {
            mobileMenu.classList.add('hidden');
          }, 300);
          document.body.style.overflow = '';
        }
      }

      menuButton?.addEventListener('click', openMenu);
      closeButton?.addEventListener('click', closeMenu);
      mobileMenu?.addEventListener('click', (e) => {
        if (e.target === mobileMenu) closeMenu();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileMenu && !mobileMenu.classList.contains('hidden')) {
          closeMenu();
        }
      });
    </script>

    <!-- Header scroll effect -->
    <script>
      const header = document.getElementById('main-header');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          header?.classList.add('bg-[#1a1a1a]/95', 'backdrop-blur-md', 'border-b', 'border-white/5');
          header?.classList.remove('bg-transparent');
        } else {
          header?.classList.remove('bg-[#1a1a1a]/95', 'backdrop-blur-md', 'border-b', 'border-white/5');
          header?.classList.add('bg-transparent');
        }
      });
    </script>
  </body>
</html>
